/* Reset basic styles */
* {
  box-sizing: border-box;
  margin: 0;
  padding: 0;
  font-family: -apple-system, BlinkMacSystemFont, "Segoe UI", Roboto, Helvetica, Arial, sans-serif;
}

body {
  background-color: #f4f5f9; /* Light gray background from image */
  padding: 10px;
  height: 100vh;
  display: flex;
  justify-content: center;
}

/* The Main App Wrapper */
.pos-app {
  display: flex;
  width: 100%;
  max-width: 1200px;
  gap: 15px; /* Spacing between the 3 columns */
}

/* --- COLUMN 1: Sidebar --- */
.sidebar {
  width: 70px;
  background-color: #ffffff;
  border-radius: 16px;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 20px 0;
  flex-shrink: 0;
}

.nav-icons .icon {
  margin: 20px 0;
  font-size: 20px;
  color: #a0a0a0;
}

/* --- COLUMN 2: Main Content --- */
.main-content {
  flex-grow: 1; /* Takes up all remaining middle space */
  display: flex;
  flex-direction: column;
}

.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 20px;
}

.search-bar {
  background: #ffffff;
  padding: 10px 15px;
  border-radius: 20px;
  display: flex;
  align-items: center;
}

.search-bar input {
  border: none;
  outline: none;
  margin-left: 10px;
}

.category-pills {
  display: flex;
  gap: 10px;
  margin-bottom: 20px;
}

.pill {
  padding: 8px 16px;
  border: none;
  border-radius: 12px;
  background: #ffffff;
  font-weight: 600;
}

.pill.active {
  background: #2b2b2b;
  color: #ffffff;
}

/* Product Grid Layout */
.product-grid {
  display: grid;
  grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
  gap: 15px;
}

.product-card {
  background: #ffffff;
  border-radius: 16px;
  padding: 10px;
  display: flex;
  flex-direction: column;
}

.image-box {
  background: #f4f5f9;
  height: 120px;
  border-radius: 12px;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40px;
  margin-bottom: 10px;
}

.price-row {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-top: 10px;
}

.add-btn {
  background: #111;
  color: white;
  border: none;
  border-radius: 50%;
  width: 25px;
  height: 25px;
  cursor: pointer;
}

/* --- COLUMN 3: Cart Section --- */
.cart-section {
  width: 320px;
  background-color: #ffffff;
  border-radius: 16px;
  padding: 20px;
  display: flex;
  flex-direction: column;
  flex-shrink: 0;
}

.cart-summary {
  margin-top: auto; /* Pushes summary to the bottom */
  background: #f8f9fc;
  padding: 15px;
  border-radius: 12px;
}

.summary-line {
  display: flex;
  justify-content: space-between;
  margin-bottom: 8px;
  color: #666;
  font-size: 14px;
}

.summary-total {
  display: flex;
  justify-content: space-between;
  font-weight: bold;
  font-size: 18px;
  margin: 15px 0;
}

.checkout-btn {
  width: 100%;
  padding: 15px;
  background-color: #4b00ff; /* The purple from your image */
  color: white;
  border: none;
  border-radius: 12px;
  font-weight: bold;
  font-size: 16px;
}
